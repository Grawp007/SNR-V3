{
  "__inputs": [{ "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }],
  "title": "SNR V3 — Operations",
  "uid": "snr-v3-ops",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "type": "stat", "title": "Analysis queue depth", "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [{ "expr": "sum(snr_analysis_queue_depth)", "legendFormat": "queued+active" }]
    },
    {
      "type": "timeseries", "title": "Analysis queue depth by state", "gridPos": { "h": 6, "w": 18, "x": 6, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [{ "expr": "snr_analysis_queue_depth", "legendFormat": "{{state}}" }]
    },
    {
      "type": "timeseries", "title": "Analysis runs/min (by result)", "gridPos": { "h": 7, "w": 12, "x": 0, "y": 6 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [{ "expr": "sum by (result) (rate(snr_analysis_runs_total[5m])) * 60", "legendFormat": "{{result}}" }]
    },
    {
      "type": "timeseries", "title": "Analysis duration (p50 / p95)", "gridPos": { "h": 7, "w": 12, "x": 12, "y": 6 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "histogram_quantile(0.5, sum(rate(snr_analysis_duration_seconds_bucket[10m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(snr_analysis_duration_seconds_bucket[10m])) by (le))", "legendFormat": "p95" }
      ]
    },
    {
      "type": "timeseries", "title": "Worker jobs processed/min", "gridPos": { "h": 7, "w": 12, "x": 0, "y": 13 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [{ "expr": "sum by (result) (rate(snr_jobs_processed_total[5m])) * 60", "legendFormat": "{{result}}" }]
    },
    {
      "type": "timeseries", "title": "HTTP requests/min (by status)", "gridPos": { "h": 7, "w": 12, "x": 12, "y": 13 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [{ "expr": "sum by (status) (rate(snr_http_requests_total[5m])) * 60", "legendFormat": "{{status}}" }]
    },
    {
      "type": "timeseries", "title": "Feed polls/min (by type/result)", "gridPos": { "h": 7, "w": 12, "x": 0, "y": 20 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [{ "expr": "sum by (type, result) (rate(snr_feed_polls_total[15m])) * 60", "legendFormat": "{{type}} {{result}}" }]
    },
    {
      "type": "timeseries", "title": "Feed items ingested/hr (by type)", "gridPos": { "h": 7, "w": 12, "x": 12, "y": 20 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [{ "expr": "sum by (type) (rate(snr_feed_items_ingested_total[1h])) * 3600", "legendFormat": "{{type}}" }]
    }
  ]
}
