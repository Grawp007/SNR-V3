{
  "name": "snr-v3",
  "version": "3.0.0",
  "description": "SNR V3 — Signal-to-Noise: Enterprise CTI workbench (Postgres, async jobs, integration API, threat-intel feeds, detection-as-code)",
  "private": true,
  "scripts": {
    "dev": "concurrently -n server,worker,client -c blue,magenta,green \"npm run dev:server\" \"npm run dev:worker\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:worker": "tsx watch server/worker.ts",
    "dev:client": "vite",
    "build": "vite build",
    "start": "tsx server/index.ts",
    "worker": "tsx server/worker.ts",
    "lint": "eslint . && tsc --noEmit",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"server/**/*.ts\" \"scripts/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"server/**/*.ts\" \"scripts/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:backup": "tsx scripts/db-backup.ts",
    "db:restore": "tsx scripts/db-restore.ts",
    "migrate:sqlite": "tsx scripts/sqlite-to-postgres.ts",
    "check:actors": "tsx scripts/check-actors.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@tiptap/react": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "@types/dagre": "^0.7.54",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dagre": "^0.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "html-to-image": "^1.11.13",
    "jsonrepair": "^3.13.2",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.469.0",
    "multer": "^2.1.1",
    "openai": "^6.32.0",
    "pg": "^8.21.0",
    "pg-boss": "^12.19.1",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-is": "^19.2.4",
    "react-markdown": "^10.1.0",
    "reactflow": "^11.11.4",
    "recharts": "^3.8.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "tiptap-markdown": "^0.9.0",
    "tsx": "^4.22.4",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/archiver": "^6.0.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.20.0",
    "@types/pino": "^7.0.4",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^6.0.7",
    "vitest": "^4.1.0"
  },
  "type": "module"
}
